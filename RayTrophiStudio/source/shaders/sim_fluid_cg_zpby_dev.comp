// sim_fluid_cg_zpby_dev.comp
// MGPCG device-resident scalars: s = z + beta*s, beta from the GPU scalars
// buffer ([4]). No-ops when the degenerate flag ([6]) is set. Requires
// shaderFloat64.
#version 450
layout(local_size_x = 256) in;

layout(push_constant) uniform PC {
    int   nx; int ny; int nz;
    int   boundary;
    float voxel_size;
    float dt;
    float sor_omega;
    int   iterations;
    int   parity;
    float density_correction;
    int   particles_per_cell;
    int   variational;
    int   gfm_active;
} pc;

layout(set = 0, binding = 0) buffer S                 { float s[]; };
layout(set = 0, binding = 1) readonly buffer Z        { float z[]; };
layout(set = 0, binding = 2) readonly buffer Scalars  { double scalars[]; };

void main() {
    int id = int(gl_GlobalInvocationID.x);
    if (id >= pc.nx * pc.ny * pc.nz) return;
    if (scalars[6] != 0.0LF) return; // degenerate — state frozen
    s[id] = z[id] + float(scalars[4]) * s[id];
}
