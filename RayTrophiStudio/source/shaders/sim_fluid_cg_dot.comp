// sim_fluid_cg_dot.comp
// MGPCG: partials[workgroup] = sum_block(x*y) accumulated in DOUBLE, summed on
// the host. Double accumulation mirrors the CPU PCG's double dot products —
// essential for CG stability at scale (see fluid_cg_dot_kernel).
// REQUIRES the shaderFloat64 device feature; the Vulkan sim backend gates this
// kernel on it and the host falls back to CPU PCG when unavailable.
#version 450
layout(local_size_x = 256) in;

layout(push_constant) uniform PC {
    int   nx; int ny; int nz;
    int   boundary;
    float voxel_size;
    float dt;
    float sor_omega;
    int   iterations;
    int   parity;
    float density_correction;
    int   particles_per_cell;
    int   variational;
    int   gfm_active;
} pc;

layout(set = 0, binding = 0) readonly buffer X { float x[]; };
layout(set = 0, binding = 1) readonly buffer Y { float y[]; };
layout(set = 0, binding = 2) buffer Partials   { double partials[]; };

shared double sdata[256];

void main() {
    int cell_count = pc.nx * pc.ny * pc.nz;
    uint tid = gl_LocalInvocationID.x;
    int  id  = int(gl_GlobalInvocationID.x);
    sdata[tid] = (id < cell_count) ? (double(x[id]) * double(y[id])) : 0.0LF;
    barrier();
    for (uint stride = 128u; stride > 0u; stride >>= 1u) {
        if (tid < stride) sdata[tid] += sdata[tid + stride];
        barrier();
    }
    if (tid == 0u) partials[gl_WorkGroupID.x] = sdata[0];
}
