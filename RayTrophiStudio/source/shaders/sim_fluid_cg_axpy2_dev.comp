// sim_fluid_cg_axpy2_dev.comp
// MGPCG device-resident scalars, fused pair update (Vulkan-only — CUDA's
// fused loop keeps alpha on the host):
//   p += alpha * s ; r -= alpha * As
// in one dispatch, with alpha read from the GPU scalars buffer ([3]). No-ops
// when the degenerate flag ([6]) is set — mirrors the host loop breaking
// before applying alpha when sAs collapsed (same contract as
// sim_fluid_cg_axpy_dev, which this replaces two dispatches of).
// Requires shaderFloat64.
#version 450
layout(local_size_x = 256) in;

layout(push_constant) uniform PC {
    int   nx; int ny; int nz;
    int   boundary;
    float voxel_size;
    float dt;
    float sor_omega;
    int   iterations;
    int   parity;
    float density_correction;
    int   particles_per_cell;
    int   variational;
    int   gfm_active;
} pc;

layout(set = 0, binding = 0) buffer Pressure          { float p[]; };
layout(set = 0, binding = 1) readonly buffer Search   { float s[]; };
layout(set = 0, binding = 2) buffer Residual          { float r[]; };
layout(set = 0, binding = 3) readonly buffer As       { float As_v[]; };
layout(set = 0, binding = 4) readonly buffer Scalars  { double scalars[]; };

void main() {
    int id = int(gl_GlobalInvocationID.x);
    if (id >= pc.nx * pc.ny * pc.nz) return;
    if (scalars[6] != 0.0LF) return; // degenerate — state frozen
    float a = float(scalars[3]);
    p[id] += a * s[id];
    r[id] -= a * As_v[id];
}
