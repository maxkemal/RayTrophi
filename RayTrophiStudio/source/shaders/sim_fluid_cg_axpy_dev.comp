// sim_fluid_cg_axpy_dev.comp
// MGPCG device-resident scalars: y += sign * alpha * x, where alpha lives in
// the GPU scalars buffer ([3]) and sign (+1/-1) rides in pc.sor_omega. No-ops
// when the degenerate flag ([6]) is set — mirrors the host loop breaking
// before applying alpha when sAs collapsed. Requires shaderFloat64.
#version 450
layout(local_size_x = 256) in;

layout(push_constant) uniform PC {
    int   nx; int ny; int nz;
    int   boundary;
    float voxel_size;
    float dt;
    float sor_omega; // sign: +1 or -1
    int   iterations;
    int   parity;
    float density_correction;
    int   particles_per_cell;
    int   variational;
    int   gfm_active;
} pc;

layout(set = 0, binding = 0) buffer Y                 { float y[]; };
layout(set = 0, binding = 1) readonly buffer X        { float x[]; };
layout(set = 0, binding = 2) readonly buffer Scalars  { double scalars[]; };

void main() {
    int id = int(gl_GlobalInvocationID.x);
    if (id >= pc.nx * pc.ny * pc.nz) return;
    if (scalars[6] != 0.0LF) return; // degenerate — state frozen
    float a = pc.sor_omega * float(scalars[3]);
    y[id] += a * x[id];
}
